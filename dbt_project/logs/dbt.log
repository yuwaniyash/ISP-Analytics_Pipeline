  create  table "isp_db"."public"."fact_usage__dbt_tmp"
  
  
    as
  
  (
    SELECT
    u.log_id,
    u.customer_id,
    u.date,
    d.month_number,
    d.month_name,
    d.quarter,
    d.year,
    d.is_weekend,
