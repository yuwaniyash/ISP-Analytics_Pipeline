LEFT JOIN "isp_db"."public"."dim_dates" d ON u.date = d.date
LEFT JOIN "isp_db"."public"."dim_plans" p ON u.customer_id = (
    SELECT customer_id FROM "isp_db"."public"."dim_customers"
    WHERE customer_id = u.customer_id LIMIT 1
)
  );
  
