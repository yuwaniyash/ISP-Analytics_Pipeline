  create view "isp_db"."public"."stg_customers__dbt_tmp"
    
    
  as (
    SELECT
    customer_id,
    name,
    region,
    plan,
    signup_date,
    CASE
        WHEN is_churned = 1 THEN 'Churned'
        ELSE 'Active'
    END AS customer_status,
    CASE
