, 'unique_id': 'macro.dbt.default__get_powers_of_two', 'macro_sql': '{% macro default__get_powers_of_two(upper_bound) %}\n\n    {% if upper_bound <= 0 %}\n    {{ exceptions.raise_compiler_error("upper bound must be positive") }}\n    {% endif %}\n\n    {% for _ in range(1, 100) %}\n       {% if upper_bound <= 2 ** loop.index %}{{ return(loop.index) }}{% endif %}\n    {% endfor %}\n\n{% endmacro %}', 'depends_on': {'macros': []}, 'description': '', 'meta': {}, 'docs': {'show': True, 'node_color': None}, 'config': {'meta': {}, 'docs': {'show': True, 'node_color': None}}, 'patch_path': None, 'arguments': [], 'created_at': 1781873213.75491, 'supported_languages': None}, 'macro.dbt.generate_series': {'name': 'generate_series', 'resource_type': 'macro', 'package_name': 'dbt', 'path': 'macros\\utils\\generate_series.sql', 'original_file_path': 'macros\\utils\\generate_series.sql', 'unique_id': 'macro.dbt.generate_series', 'macro_sql': "{% macro generate_series(upper_bound) %}\n    {{ return(adapter.dispatch('generate_series', 'dbt')(upper_bound)) }}\n{% endmacro %}", 'depends_on': {'macros': ['macro.dbt.default__generate_series']}, 'description': '', 'meta': {}, 'docs': {'show': True, 'node_color': None}, 'config': {'meta': {}, 'docs': {'show': True, 'node_color': None}}, 'patch_path': None, 'arguments': [], 'created_at': 1781873213.755246, 'supported_languages': None}, 'macro.dbt.default__generate_series': {'name': 'default__generate_series', 'resource_type': 'macro', 'package_name': 'dbt', 'path': 'macros\\utils\\generate_series.sql', 'original_file_path': 'macros\\utils\\generate_series.sql', 'unique_id': 'macro.dbt.default__generate_series', 'macro_sql': '{% macro default__generate_series(upper_bound) %}\n\n    {% set n = dbt.get_powers_of_two(upper_bound) %}\n\n    with p as (\n        select 0 as generated_number union all select 1\n    ), unioned as (\n\n    select\n\n    {% for i in range(n) %}\n    p{{i}}.generated_number * power(2, {{i}})\n    {% if not loop.last %} + {% endif %}\n    {% endfor %}\n    + 1\n    as generated_number\n\n    from\n\n    {% for i in range(n) %}\n    p as p{{i}}\n    {% if not loop.last %} cross join {% endif %}\n    {% endfor %}\n\n    )\n\n    select *\n    from unioned\n    where generated_number <= {{upper_bound}}\n    order by generated_number\n\n{% endmacro %}', 'depends_on': {'macros': ['macro.dbt.get_powers_of_two']}, 'description': '', 'meta': {}, 'docs': {'show': True, 'node_color': None}, 'config': {'meta': {}, 'docs': {'show': True, 'node_color': None}}, 'patch_path': None, 'arguments': [], 'created_at': 1781873213.7561612, 'supported_languages': None}, 'macro.dbt.hash': {'name': 'hash', 'resource_type': 'macro', 'package_name': 'dbt', 'path': 'macros\\utils\\hash.sql', 'original_file_path': 'macros\\utils\\hash.sql', 'unique_id': 'macro.dbt.hash', 'macro_sql': "{% macro hash(field) -%}\n  {{ return(adapter.dispatch('hash', 'dbt') (field)) }}\n{%- endmacro %}", 'depends_on': {'macros': ['macro.dbt.default__hash']}, 'description': '', 'meta': {}, 'docs': {'show': True, 'node_color': None}, 'config': {'meta': {}, 'docs': {'show': True, 'node_color': None}}, 'patch_path': None, 'arguments': [], 'created_at': 1781873213.756606, 'supported_languages': None}, 'macro.dbt.default__hash': {'name': 'default__hash', 'resource_type': 'macro', 'package_name': 'dbt', 'path': 'macros\\utils\\hash.sql', 'original_file_path': 'macros\\utils\\hash.sql', 'unique_id': 'macro.dbt.default__hash', 'macro_sql': "{% macro default__hash(field) -%}\n    md5(cast({{ field }} as {{ api.Column.translate_type('string') }}))\n{%- endmacro %}", 'depends_on': {'macros': []}, 'description': '', 'meta': {}, 'docs': {'show': True, 'node_color': None}, 'config': {'meta': {}, 'docs': {'show': True, 'node_color': None}}, 'patch_path': None, 'arguments': [], 'created_at': 1781873213.7569187, 'supported_languages': None}, 'macro.dbt.intersect': {'name': 'intersect', 'resource_type': 'macro', 'package_name': 'dbt', 'path': 'ma