    SUM(f.exceeded_limit) AS total_exceeded_count
FROM "isp_db"."public"."fact_usage" f
GROUP BY f.year, f.quarter, f.month_number, f.month_name, f.plan_name, f.plan_tier
ORDER BY f.year, f.month_number, f.plan_tier
  );
  
