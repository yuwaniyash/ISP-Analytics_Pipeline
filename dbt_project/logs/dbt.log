  create  table "isp_db"."public"."mart_usage_trends__dbt_tmp"
  
  
    as
  
  (
    SELECT
    f.year,
    f.quarter,
    f.month_number,
    f.month_name,
    f.plan_name,
    f.plan_tier,
    COUNT(DISTINCT f.customer_id) AS active_customers,
